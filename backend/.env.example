# LLM Provider: openai | gemini
LLM_PROVIDER=gemini

# API Keys (set at least one)
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Flowise (optional — falls back to direct LLM calls)
FLOWISE_URL=http://localhost:3000
FLOWISE_CHATFLOW_ID=

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hackathon_knowledge

# PostgreSQL
DATABASE_URL=postgresql://hackathon:hackathon@localhost:5432/hackathon_partner

# Web Search (optional)
TAVILY_API_KEY=
SERPER_API_KEY=

# CORS
FRONTEND_URL=http://localhost:3001
